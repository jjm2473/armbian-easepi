#!/bin/bash

systemctl disable istorenext-init-network

if [ -f /root/.default-network ]; then
	. /root/.default-network
	rm -f /root/.default-network
else
	DEFAULT_INTERFACE=$( ( cd /sys/class/net && ls | grep ^eth ) | sort -V | tail -1 )
fi

[ -z "${DEFAULT_INTERFACE}" ] && exit 0

cat > /etc/network/interfaces <<EOF
# This file was generated by the iStoreNext installer
auto lo
iface lo inet loopback

auto ${DEFAULT_INTERFACE}
iface ${DEFAULT_INTERFACE} inet static
    address 192.168.1.1
    netmask 255.255.255.0
EOF
